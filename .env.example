# ==========================================================================
# 환경변수 템플릿 (실제 값은 .env 에 저장, .env 는 git 제외)
# 사용: cp .env.example .env  → 편집
# ==========================================================================

# ---- 애플리케이션 (backend가 app.config.py 로 읽음) ----
APP_ENV=local
APP_DEBUG=true
APP_BASE_URL=http://localhost:8000

# Auth
# JWT 시크릿은 32바이트 이상 임의 문자열 (openssl rand -hex 32)
APP_JWT_SECRET=change-me-change-me-change-me-change-me-32b
APP_JWT_ACCESS_TTL_MIN=60
APP_JWT_REFRESH_TTL_DAYS=14

# Database (async driver)
# Docker 운영 (Python 3.12) = asyncpg, 로컬 (Python 3.14) = psycopg3
# 자세한 결정 배경: docs/adr/0001-postgres-driver-dual-asyncpg-psycopg.md
APP_DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/datapipeline
# APP_DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/datapipeline   # 로컬 Python 3.14

# Redis
APP_REDIS_URL=redis://localhost:6379/0

# Object Storage (로컬 = MinIO, 운영 = NCP Object Storage)
APP_OS_ENDPOINT=http://localhost:9000
APP_OS_ACCESS_KEY=minioadmin
APP_OS_SECRET_KEY=minioadmin
APP_OS_BUCKET=datapipeline-raw
APP_OS_REGION=kr-standard
APP_OS_SCHEME=minio

# CORS (Phase 1.2.9 프론트 연결 시 사용)
APP_CORS_ORIGINS=http://localhost:5173

# 로깅 (로컬은 pretty, 운영은 json)
APP_LOG_LEVEL=INFO
APP_LOG_JSON=false

# ---- 외부 AI / OCR 서비스 (Phase 2부터 실제 값 필요) ----
APP_CLOVA_OCR_URL=
APP_CLOVA_OCR_SECRET=
APP_HYPERCLOVA_API_KEY=

# Upstage Document OCR (Phase 2.2.4 폴백 provider)
APP_UPSTAGE_OCR_URL=https://api.upstage.ai
APP_UPSTAGE_API_KEY=

# OCR 정책 (Phase 2.2.4)
# 평균 confidence 가 이 값 미만이면 run.crowd_task placeholder 적재.
APP_OCR_CONFIDENCE_THRESHOLD=0.85

# HyperCLOVA Studio Embedding (Phase 2.2.5)
APP_HYPERCLOVA_API_URL=https://clovastudio.stream.ntruss.com
APP_HYPERCLOVA_EMBEDDING_APP=/testapp/v1/api-tools/embedding/v2

# 표준화 정책 (Phase 2.2.5)
# trigram fuzzy match 통과 임계 (0~1) — 임계 미만이면 임베딩 단계로.
APP_STD_TRIGRAM_THRESHOLD=0.7
# 임베딩 cosine 통과 임계 — 임계 미만이면 crowd_task placeholder.
APP_STD_EMBEDDING_THRESHOLD=0.85
# pgvector 차원 — mart.standard_code.embedding 컬럼 정의와 일치 필요.
APP_EMBEDDING_DIM=1536

# 가격 팩트 게이트 (Phase 2.2.6)
# 80~95% confidence 구간 중 이 비율을 crowd_task("price_fact_sample_review") 로 적재.
APP_PRICE_FACT_SAMPLE_RATE=0.05

# ---- docker compose 가 직접 읽음 (infra/docker-compose.yml) ----
# PostgreSQL
POSTGRES_DB=datapipeline
POSTGRES_USER=app
POSTGRES_PASSWORD=app

# MinIO (운영 키와 절대 같게 쓰지 말 것, 로컬 전용)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Grafana (Phase 1.2.10 관제)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Airflow (Phase 2.2.3) — LocalExecutor 로 시작, Phase 4 NKS 에서 CeleryExecutor
AIRFLOW_ADMIN_USER=airflow
AIRFLOW_ADMIN_PASSWORD=airflow
# Fernet key — 운영 시 반드시 새로 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=fz1Iia1OQHs8ECpOMGiTm0Sd1mI0r9QlmTkKt2qMBqs=
# Linux 호스트에서 호스트 UID 와 컨테이너 50000 권한 충돌 회피 (`id -u` 결과로 override).
AIRFLOW_UID=50000

# ---- 호스트 포트 (다른 컨테이너와 충돌 시 override) ----
# 기본값을 바꾸려면 주석 해제 + APP_DATABASE_URL / APP_REDIS_URL / APP_OS_ENDPOINT 도 같이 수정
# POSTGRES_HOST_PORT=5433
# REDIS_HOST_PORT=6380
# MINIO_API_PORT=9010
# MINIO_CONSOLE_PORT=9011
