# Phase 5.1 staging — `.env.staging` 템플릿 (회사 서버 / 사내망 only).
#
# 사용법:
#   cp infra/staging.env.example .env.staging
#   bash scripts/generate_staging_secrets.sh >> .env.staging   # 비밀값 자동 생성
#   chmod 600 .env.staging
#
# 또는 staging_bootstrap.sh 가 자동으로 위 작업 수행.

# ──────────────────────────────────────────────────────────────────────────────
# 환경 / 시간대
# ──────────────────────────────────────────────────────────────────────────────
APP_ENV=staging
APP_DEBUG=false
TZ=Asia/Seoul

# ──────────────────────────────────────────────────────────────────────────────
# 호스트 포트 (서버 IP 172.30.1.131 기준 — staging 충돌 회피)
# ──────────────────────────────────────────────────────────────────────────────
FRONTEND_HOST_PORT=8080      # http://172.30.1.131:8080 (사용자 진입)
BACKEND_HOST_PORT=8000       # http://172.30.1.131:8000 (디버깅)
POSTGRES_HOST_PORT=5434
REDIS_HOST_PORT=6380
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ──────────────────────────────────────────────────────────────────────────────
# Postgres / Redis / MinIO — 비밀값은 generate_staging_secrets.sh 가 채움
# ──────────────────────────────────────────────────────────────────────────────
POSTGRES_DB=datapipeline
POSTGRES_USER=app
# POSTGRES_PASSWORD=<RANDOM_32 — staging_bootstrap.sh 가 자동 생성>

# Redis 는 password 없음 (사내망 only — Redis ACL 은 Phase 6 NKS 이관 시).

MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=<RANDOM_32>
APP_OS_BUCKET=datapipeline-staging

# ──────────────────────────────────────────────────────────────────────────────
# 애플리케이션 비밀
# ──────────────────────────────────────────────────────────────────────────────
# APP_JWT_SECRET=<RANDOM_64HEX>

# CORS — frontend 가 backend 에 접근하는 origin.
APP_CORS_ORIGINS=http://172.30.1.131:8080,http://localhost:8080

# ──────────────────────────────────────────────────────────────────────────────
# 첫 ADMIN 계정 (migrate 컨테이너가 seed)
# ──────────────────────────────────────────────────────────────────────────────
ADMIN_LOGIN_ID=admin
ADMIN_DISPLAY_NAME=Staging Admin
ADMIN_EMAIL=fishnoon@example.com
# ADMIN_PASSWORD=<RANDOM_24 — bootstrap.sh 가 자동 생성, 사용자에게 *최초 1회* 출력>

# ──────────────────────────────────────────────────────────────────────────────
# 외부 API — Phase 5.1 staging 은 모두 비활성. 사용 시 값 입력 후 재시작.
# ──────────────────────────────────────────────────────────────────────────────
APP_CLOVA_OCR_URL=
APP_CLOVA_OCR_SECRET=
APP_UPSTAGE_OCR_URL=
APP_UPSTAGE_API_KEY=
APP_HYPERCLOVA_API_KEY=
APP_HYPERCLOVA_API_URL=
APP_HYPERCLOVA_EMBEDDING_APP=

# Slack / Sentry — 비활성.
APP_SLACK_WEBHOOK_URL=
APP_SENTRY_DSN=
