{
  "title": "Pipeline Hub — Core",
  "uid": "pipeline-hub-core",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["pipeline-hub", "phase-1"],
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "수집 QPS (1m)",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(ingest_requests_total[1m]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": { "unit": "ops", "decimals": 2 }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Dedup 비율 (1m)",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(ingest_dedup_total[1m])) / clamp_min(sum(rate(ingest_requests_total[1m])), 0.001)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "red", "value": 0.7 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "수집 누적 (오늘)",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(increase(ingest_requests_total{status=\"created\"}[24h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "수집 바이트 (24h)",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(increase(ingest_bytes_total[24h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP p95 latency by path",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (path, le) (rate(http_request_duration_seconds_bucket[5m])))",
          "refId": "A",
          "legendFormat": "{{path}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP 5xx rate (5m)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "sum by (path) (rate(http_requests_total{status=~\"5..\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{path}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "수집 요청 (source × kind, 5m)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "sum by (source_code, kind, status) (rate(ingest_requests_total[5m]))",
          "refId": "A",
          "legendFormat": "{{source_code}} / {{kind}} / {{status}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Outbox PENDING (placeholder — Phase 2)",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "outbox_pending_total or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "DB pool 사용중",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 22 },
      "targets": [{ "expr": "db_pool_in_use", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ]
}
